# Copy this file to .env for local development.
# Do not commit .env.

# WeWe RSS local service used by config/sources.yaml.
WEWE_RSS_BASE_URL=http://localhost:4000

# Optional WeChat article parsing API.
READGZH_API_KEY=

# OpenAI-compatible model gateway.
# The defaults match the current xfx.plus reference config, but keep real keys only in .env.
AI_BASE_URL=https://xfx.plus
AI_API_KEY=
AI_MODEL=gpt-5.5
AI_WIRE_API=responses
AI_REASONING_EFFORT=medium
AI_TIMEOUT=60
AI_MAX_TOKENS=4096
